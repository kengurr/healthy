# Zdravdoma Environment Variables Template
# Copy to .env and fill in actual values
# NEVER commit this file to version control

# =============================================================================
# APPLICATION
# =============================================================================

SPRING_PROFILES_ACTIVE=staging
APP_PORT=8080

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=zdravdoma
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=changeme

# =============================================================================
# REDIS
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# KAFKA
# =============================================================================

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================

# Minimum 256-bit secret for production
JWT_SECRET=dev-secret-key-change-in-production-min-256-bits
ACCESS_TOKEN_EXPIRY_MS=900000
REFRESH_TOKEN_EXPIRY_MS=604800000

# =============================================================================
# AWS S3
# =============================================================================

AWS_REGION=eu-central-1
AWS_S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 Bucket names
AWS_S3_BUCKET_DOCUMENTS=zdravdoma-documents
AWS_S3_BUCKET_REPORTS=zdravdoma-reports
AWS_S3_BUCKET_MEDIA=zdravdoma-media

# =============================================================================
# EMAIL (SendGrid)
# =============================================================================

MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=

# =============================================================================
# STRIPE (Billing)
# =============================================================================

STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# =============================================================================
# TWILIO (SMS Notifications)
# =============================================================================

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =============================================================================
# FCM (Firebase Cloud Messaging)
# =============================================================================

FCM_SERVER_KEY=
FCM_SENDER_ID=

# =============================================================================
# SENTRY (Error Tracking)
# =============================================================================

SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# =============================================================================
# EXTERNAL APIs (NIJZ, ZZZS)
# =============================================================================

# NIJZ API
NIJZ_API_URL=
NIJZ_API_KEY=

# ZZZS API
ZZZS_API_URL=
ZZZS_API_KEY=

# =============================================================================
# SENTRY RELEASE (auto-populated by CI/CD)
# =============================================================================

# SENTRY_RELEASE=${GITHUB_SHA}
