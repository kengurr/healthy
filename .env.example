# Zdravdoma Environment Variables
# Copy this file to .env in each environment (backend, patient-app, provider-app, admin-portal)
# DO NOT commit real values to version control

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=zdravdoma
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=changeme

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# AWS S3
# =============================================================================
AWS_S3_ENDPOINT=https://s3.amazonaws.com
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=changeme
AWS_S3_BUCKET_DOCUMENTS=zdravdoma-documents
AWS_S3_BUCKET_REPORTS=zdravdoma-reports
AWS_S3_BUCKET_MEDIA=zdravdoma-media

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET=your-256-bit-secret-key-change-in-production-minimum-32-chars
JWT_ACCESS_TOKEN_EXPIRY_MS=900000
JWT_REFRESH_TOKEN_EXPIRY_MS=604800000

# =============================================================================
# STRIPE PAYMENTS
# =============================================================================
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# FIREBASE CLOUD MESSAGING (FCM)
# =============================================================================
FCM_PROJECT_ID=zdravdoma-xxxxx
# Firebase service account JSON (paste entire JSON, no newlines)
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"zdravdoma-xxxxx"...}

# =============================================================================
# APPLE PUSH NOTIFICATIONS (APNs)
# =============================================================================
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=YYYYYYYYYY
APNS_BUNDLE_ID=com.zdravdoma.provider
# Base64-encoded .p8 private key (-----BEGIN PRIVATE KEY----- ... -----END PRIVATE KEY-----)
APNS_PRIVATE_KEY_BASE64=

# =============================================================================
# TWILIO SMS
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# SENDGRID EMAIL
# =============================================================================
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_FROM_EMAIL=noreply@zdravdoma.si
SENDGRID_FROM_NAME=Zdravdoma

# =============================================================================
# HEALTHCARE INTEGRATIONS (NIJZ / ZZZS)
# =============================================================================
NIJZ_SANDBOX_URL=https://sandbox.nijz.si/api/v1
NIJZ_API_KEY=changeme
ZZZS_API_KEY=changeme
ZZZS_SANDBOX_URL=https://sandbox.zzzs.si/api/v1

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev
BACKEND_BASE_URL=http://localhost:8080/api/v1
FRONTEND_BASE_URL=http://localhost:3000

# =============================================================================
# KAFKA
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# =============================================================================
# MONITORING
# =============================================================================
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxx
GRAFANA_PASSWORD=changeme
PROMETHEUS_PASSWORD=changeme

# =============================================================================
# SLACK (CI/CD NOTIFICATIONS)
# =============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXXXXXX/YYYYYYYYY/ZZZZZZZZZZZZZZZZ

# =============================================================================
# DJANGO SECRET KEY (Admin Portal)
# =============================================================================
DJANGO_SECRET_KEY=changeme-minimum-50-char-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
